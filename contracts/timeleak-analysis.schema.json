{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TimeLeakAnalysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "localDate",
    "timezone",
    "daySummary",
    "leak",
    "repair",
    "metrics",
    "calendarEvent",
    "shareResult"
  ],
  "properties": {
    "status": { "enum": ["pass", "limited_result"] },
    "localDate": { "type": "string", "format": "date" },
    "timezone": { "type": "string", "minLength": 1 },
    "daySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalMinutes", "sleepMinutes", "fixedMinutes", "maintenanceMinutes", "intentionalRestMinutes", "unownedMinutes"],
      "properties": {
        "totalMinutes": { "const": 1440 },
        "sleepMinutes": { "type": "integer", "minimum": 0, "maximum": 1440 },
        "fixedMinutes": { "type": "integer", "minimum": 0, "maximum": 1440 },
        "maintenanceMinutes": { "type": "integer", "minimum": 0, "maximum": 1440 },
        "intentionalRestMinutes": { "type": "integer", "minimum": 0, "maximum": 1440 },
        "unownedMinutes": { "type": "integer", "minimum": 0, "maximum": 1440 }
      }
    },
    "leak": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label", "explanation", "confidence"],
      "properties": {
        "type": { "enum": ["fragmented_evening", "transition_drift", "chore_scatter", "work_spillover", "priority_orphan", "screen_drift"] },
        "label": { "type": "string" },
        "explanation": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "instruction", "whySmallestChange"],
      "properties": {
        "headline": { "type": "string" },
        "instruction": { "type": "string" },
        "whySmallestChange": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["beforeProtectedMinutes", "afterProtectedMinutes", "plannedDays", "monthlyReclaimMinutes"],
      "properties": {
        "beforeProtectedMinutes": { "type": "integer", "minimum": 0 },
        "afterProtectedMinutes": { "type": "integer", "minimum": 0 },
        "plannedDays": { "type": "integer", "minimum": 1, "maximum": 31 },
        "monthlyReclaimMinutes": { "type": "integer", "minimum": 0 }
      }
    },
    "calendarEvent": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["title", "start", "end"],
      "properties": {
        "title": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" }
      }
    },
    "shareResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["beforeMinutes", "afterMinutes", "monthlyHours", "leakLabel"],
      "properties": {
        "beforeMinutes": { "type": "integer", "minimum": 0 },
        "afterMinutes": { "type": "integer", "minimum": 0 },
        "monthlyHours": { "type": "number", "minimum": 0 },
        "leakLabel": { "type": "string" }
      }
    }
  }
}

